# Copia a .env en local. En Vercel: Project → Settings → Environment Variables.

# Supabase (Project Settings → API)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Obligatorio en producción (Vercel). En local, cámbialo también.
JWT_SECRET=cambia-esto-en-produccion

# Puerto solo para npm start / node server/index.js (Vercel lo ignora)
PORT=3847

# URL pública de la app (enlaces en correos), sin barra final.
# En Vercel puedes omitirla: se usa VERCEL_URL + https automáticamente.
# Con dominio propio, pon aquí https://tudominio.com
PUBLIC_APP_URL=http://localhost:3847

# Sin Resend/SMTP: enlaces de verificación y recuperación en la respuesta JSON y en la pantalla de acceso.
# true | 1 | yes — no se envía correo para esos flujos. Úsalo solo en entornos de confianza (el enlace es secreto).
# AUTH_LINKS_IN_RESPONSE=true

# Correo (Resend o SMTP)
MAIL_FROM=Delivery <onboarding@resend.dev>
RESEND_API_KEY=

# Alternativa SMTP (si no usas Resend)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false
