# Supabase (Project Settings → API)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

JWT_SECRET=cambia-esto-en-produccion
PORT=3847

# URL base de la app en enlaces de correo (sin barra final)
PUBLIC_APP_URL=http://localhost:3847

# Correo: obligatorio para «recuperar contraseña» y confirmación de correo.
# Sin RESEND_API_KEY (o SMTP) + MAIL_FROM, la API responde error 503 al enviar.
# Resend: crea API key en https://resend.com — en producción verifica tu dominio y usa MAIL_FROM de ese dominio.
MAIL_FROM=Delivery <onboarding@resend.dev>
RESEND_API_KEY=

# Alternativa SMTP (si no usas Resend)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false
